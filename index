    <style>
        :root {
            --bg: #000000;
            --fg: #ffffff;
            --font-mono: 'JetBrains Mono', monospace;
            --font-sans: 'Inter', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            cursor: crosshair;
        }

        body, html {
            width: 100%;
            height: 100%;
            background-color: var(--bg);
            color: var(--fg);
            overflow: hidden; 
            -webkit-font-smoothing: antialiased;
        }
        
        body.is-dragging, body.is-dragging * {
            cursor: grabbing !important;
        }

        /* CRT OVERLAY */
        .crt-overlay {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 2px, 3px 100%;
            z-index: 999;
            pointer-events: none;
            opacity: 0.2;
        }

        #core-canvas {
            position: absolute;
            top: 0; left: 0;
            z-index: 0;
        }

        /* HUD ELEMENTS (Z-index 10 to stay behind panels) */
        .hud-element {
            position: absolute;
            font-family: var(--font-mono);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            z-index: 10;
        }
        .hud-top-left { top: 20px; left: 20px; }
        #audio-toggle { cursor: pointer; text-decoration: underline; opacity: 0.5; transition: opacity 0.2s; pointer-events: auto; }
        #audio-toggle:hover { opacity: 1; background: var(--fg); color: var(--bg); }

        .hud-theme-toggle { top: 60px; left: 20px; }
        #theme-toggle { cursor: pointer; text-decoration: underline; opacity: 0.5; transition: opacity 0.2s; pointer-events: auto; }
        #theme-toggle:hover { opacity: 1; background: var(--fg); color: var(--bg); }

        .hud-top-right { top: 20px; right: 20px; text-align: right; }
        .hud-weather { top: 60px; right: 20px; text-align: right; opacity: 0.7; }
        .hud-bottom-right { bottom: 35px; right: 20px; text-align: right; }
        
        /* FULL WIDTH INFINITE LOOP DATA TICKER */
        .hud-bottom-ticker { 
            position: absolute;
            bottom: 0px; left: 0; width: 100vw; 
            overflow: hidden; white-space: nowrap; 
            font-family: var(--font-mono);
            font-size: 0.7rem; letter-spacing: 0.15em;
            color: var(--fg); opacity: 0.6;
            z-index: 10; pointer-events: none;
            padding: 8px 0;
            background: var(--bg);
        }
        .ticker-track {
            display: inline-block;
            white-space: nowrap;
            animation: tickerScroll 40s linear infinite;
        }
        .ticker-track span {
            padding-right: 50px;
        }
        @keyframes tickerScroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        .hud-crosshair {
            position: absolute;
            width: 20px; height: 20px;
            z-index: 10;
        }
        .hud-crosshair::before, .hud-crosshair::after {
            content: ''; position: absolute; background: var(--fg);
        }
        .hud-crosshair::before { width: 100%; height: 1px; top: 9px; left: 0; }
        .hud-crosshair::after { height: 100%; width: 1px; left: 9px; top: 0; }
        .ch-tl { top: 40px; left: 40px; }
        .ch-tr { top: 40px; right: 40px; }
        .ch-bl { bottom: 50px; left: 40px; }
        .ch-br { bottom: 50px; right: 40px; }

        /* HERO TITLE */
        .hero {
            position: absolute;
            top: 60px; left: 50%;
            transform: translateX(-50%);
            text-align: center;
            z-index: 10;
            width: 100%;
        }
        .hero h1 {
            font-family: var(--font-mono);
            font-size: 6vw;
            font-weight: 800;
            letter-spacing: -0.05em;
            line-height: 1;
        }
        .hero p {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            margin-top: 10px;
            border: 1px solid var(--fg);
            display: inline-block;
            padding: 6px 18px;
            letter-spacing: 0.3em;
            background: var(--bg);
        }

        /* ORBITING NAVIGATION */
        .nav-container {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 20;
            pointer-events: none;
        }
        
        .nav-item {
            position: absolute;
            pointer-events: auto;
            text-decoration: none;
            color: var(--fg);
            background: var(--bg);
            font-family: var(--font-mono);
            font-weight: 700;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 12px;
            white-space: nowrap;
            transition: all 0.2s cubic-bezier(0.23, 1, 0.32, 1);
            padding: 8px 18px;
            border: 1px solid transparent;
        }

        .nav-item:hover {
            color: var(--bg);
            background: var(--fg);
            border: 1px solid var(--fg);
            transform: translate(-50%, -50%) scale(1.1) skewX(-5deg) !important;
        }

        /* P5 EASTER EGG (HORSE) - 1.2s */
        .easter-egg-container {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: 95;
            pointer-events: none;
            display: none;
            align-items: center;
            justify-content: center;
        }
        .easter-egg-active { display: flex; }
        .horse-shape {
            width: 45vw;
            min-width: 350px;
        }
        .easter-egg-dash .horse-shape { animation: horseDash 1.2s cubic-bezier(0.25, 0.1, 0.25, 1) forwards; }
        @keyframes horseDash {
            0% { transform: translateX(-120vw) translateY(10vh) skewX(-30deg) scale(1.3); }
            40% { transform: translateX(0) translateY(0) skewX(-5deg) scale(1); }
            60% { transform: translateX(0) translateY(0) skewX(-5deg) scale(1); }
            100% { transform: translateX(120vw) translateY(-10vh) skewX(25deg) scale(0.7); }
        }
        .easter-egg-drop .horse-shape { animation: horseDrop 1.2s cubic-bezier(0.25, 0.1, 0.25, 1) forwards; }
        @keyframes horseDrop {
            0% { transform: translateY(-120vh) scale(1, 1.4); }
            40% { transform: translateY(5vh) scale(1.4, 0.6); }
            60% { transform: translateY(0) scale(1, 1); }
            80% { transform: translateY(0) scale(1, 1); }
            100% { transform: translateY(120vh) scale(0.8, 1.6); }
        }
        .easter-egg-drop .speed-trails { display: none; }

        /* WIPE LAYERS */
        .wipe-container { position: fixed; z-index: 90; pointer-events: none; display: flex; }
        .wipe-slash { top: -25vh; left: -25vw; width: 150vw; height: 150vh; flex-direction: column; transform: rotate(-15deg); }
        .wipe-slash .slash { flex: 1; background: var(--fg); transform: scaleX(0); transform-origin: left; transition: transform 0.5s cubic-bezier(0.85, 0, 0.15, 1); border-bottom: 2px solid var(--bg); }
        .wipe-slash.wipe-active .slash { transform: scaleX(1); }
        .wipe-slash .slash:nth-child(2) { transition-delay: 0.08s; }
        .wipe-slash .slash:nth-child(3) { transition-delay: 0.16s; }
        .wipe-slash .slash:nth-child(4) { transition-delay: 0.24s; }
        .wipe-slash .slash:nth-child(5) { transition-delay: 0.32s; }

        .wipe-blinds { top: 0; left: 0; width: 100vw; height: 100vh; flex-direction: column; }
        .wipe-blinds .blind { flex: 1; background: var(--fg); transform: scaleX(0); transform-origin: right; transition: transform 0.4s cubic-bezier(0.85, 0, 0.15, 1); border-bottom: 4px solid var(--bg); }
        .wipe-blinds.wipe-active .blind { transform: scaleX(1); }
        .wipe-blinds .blind:nth-child(2) { transition-delay: 0.1s; }
        .wipe-blinds .blind:nth-child(4) { transition-delay: 0.2s; }

        .wipe-quad { top: 0; left: 0; width: 100vw; height: 100vh; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 4px; }
        .wipe-quad .quad { background: var(--fg); transform: scale(0); transition: transform 0.6s cubic-bezier(0.85, 0, 0.15, 1); }
        .wipe-quad.wipe-active .quad { transform: scale(1); }

        .wipe-crush { top: 0; left: 0; width: 100vw; height: 100vh; flex-direction: row; }
        .wipe-crush .pillar { flex: 1; background: var(--fg); transform: scaleY(0); transition: transform 0.5s cubic-bezier(0.85, 0, 0.15, 1); border-right: 2px solid var(--bg); }
        .wipe-crush.wipe-active .pillar { transform: scaleY(1); }

        /* CONTENT */
        .content-overlay {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: var(--bg);
            z-index: 50;
            display: none;
            padding: 60px;
            flex-direction: column;
            border: 12px solid var(--fg);
        }
        .content-active { display: flex; }

        .content-header { border-bottom: 2px solid var(--fg); padding-bottom: 20px; margin-bottom: 30px; display: flex; justify-content: space-between; align-items: flex-end; }
        .content-title { font-family: var(--font-mono); font-size: 3.5rem; text-transform: uppercase; line-height: 0.9; }
        .btn-close { background: transparent; color: var(--fg); border: 2px solid var(--fg); font-family: var(--font-mono); padding: 10px 25px; font-weight: bold; pointer-events: auto; }
        .btn-close:hover { background: var(--fg); color: var(--bg); }

        .content-body {
            flex-grow: 1;
            overflow-y: auto;
            padding-right: 20px;
            scrollbar-width: none; 
        }
        .content-body::-webkit-scrollbar { display: none; }

        .grid-layout { display: grid; grid-template-columns: 1fr 2fr; gap: 2px; background: var(--fg); border: 2px solid var(--fg); }
        .grid-cell { background: var(--bg); padding: 25px; display: flex; flex-direction: column;}
        .cell-title { font-family: var(--font-mono); font-size: 0.8rem; border-bottom: 1px solid var(--fg); margin-bottom: 15px; display: inline-block; align-self: flex-start; }
        .cell-content { font-family: var(--font-sans); font-size: 1rem; line-height: 1.5; }

        .term-list { list-style: none; font-family: var(--font-mono); font-size: 0.9rem; }
        .term-list li { margin-bottom: 25px; }
        .term-list .role { font-weight: 700; color: var(--fg); display: block; margin-top: 5px; margin-bottom: 4px; font-size: 1.1rem;}
        .term-list .date { opacity: 0.6; font-size: 0.8rem; letter-spacing: 0.1em; }
        .term-list p { font-family: var(--font-sans); color: #ccc; line-height: 1.5; margin-bottom: 5px; }

        /* EXPANDABLE SKILL MATRIX */
        .skill-matrix { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); 
            gap: 15px; 
            align-items: start;
        }
        .skill-block { 
            border: 1px solid var(--fg); 
            padding: 15px; 
            cursor: pointer; 
            transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
            background: var(--bg);
            color: var(--fg);
        }
        .skill-block:hover { 
            background: rgba(255,255,255,0.1); 
            transform: translateY(-2px);
        }
        .skill-block h4 { 
            background: var(--fg); color: var(--bg); 
            font-family: var(--font-mono); padding: 2px 8px; 
            font-size: 0.8rem; margin-bottom: 10px; display: inline-block; 
            transition: all 0.3s;
        }
        .skill-summary {
            font-family: var(--font-sans); font-size: 0.9rem; line-height: 1.4;
        }
        .skill-details {
            display: none;
            margin-top: 15px; 
            font-family: var(--font-sans); font-size: 0.95rem; line-height: 1.6;
            border-top: 1px solid currentColor; padding-top: 15px;
        }
        
        /* Expanded State Classes */
        .skill-block.expanded {
            grid-column: 1 / -1;
            background: var(--fg);
            color: var(--bg);
            transform: translateY(0);
        }
        .skill-block.expanded h4 {
            background: var(--bg);
            color: var(--fg);
        }
        .skill-block.expanded .skill-details {
            display: block;
            animation: fadeIn 0.4s ease forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .btn-extract {
            background: transparent; color: var(--fg);
            border: 2px solid var(--fg); font-family: var(--font-mono);
            font-size: 1rem; padding: 15px 30px;
            font-weight: bold; display: inline-block;
            margin-top: 30px; text-decoration: none;
            transition: all 0.2s; pointer-events: auto;
            text-align: center; width: 100%;
        }
        .btn-extract:hover {
            background: var(--fg); color: var(--bg);
            transform: translateY(-2px);
        }

        /* Utilities */
        .blinking-cursor::after {
            content: '█';
            animation: blink 1s step-start infinite;
            margin-left: 5px;
        }
        @keyframes blink { 50% { opacity: 0; } }

        @media (max-width: 768px) {
            .hero h1 { font-size: 8vw; }
            .grid-layout { grid-template-columns: 1fr; }
            .content-overlay { padding: 20px; border-width: 6px; }
            .content-title { font-size: 2rem; }
        }
    </style>
</head>

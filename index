                document.getElementById('sys-weather').innerHTML = `WTHR: ${temp}°C<br>LAPPEENRANTA`;
            } catch (e) {
                document.getElementById('sys-weather').innerHTML = `WTHR: ERR<br>LAPPEENRANTA`;
            }
        }
        fetchWeather();
        setInterval(fetchWeather, 600000);

        // --- THEME TOGGLE LOGIC ---
        const themes = [
            { name: 'WHT', color: '#ffffff', rgb: '255,255,255' },
            { name: 'GRN', color: '#00ff41', rgb: '0,255,65' },
            { name: 'AMB', color: '#ffb000', rgb: '255,176,0' }
        ];
        let currentTheme = 0;
        let currentRGB = themes[0].rgb;
        document.getElementById('theme-toggle').addEventListener('click', () => {
            currentTheme = (currentTheme + 1) % themes.length;
            document.documentElement.style.setProperty('--fg', themes[currentTheme].color);
            document.getElementById('theme-toggle').innerText = themes[currentTheme].name;
            currentRGB = themes[currentTheme].rgb;
            if(typeof SoundEngine !== 'undefined') SoundEngine.tick();

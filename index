    <script>
        // --- DECRYPTION TEXT EFFECT ---
        function scrambleText(element, originalText) {
            const chars = '!<>-_\\\\/[]{}—=+*^?#________';
            let iterations = 0;
            const maxIterations = 20;
            clearInterval(element.scrambleInterval);
            
            element.scrambleInterval = setInterval(() => {
                element.innerText = originalText.split('').map((char, index) => {
                    if (char === ' ') return ' ';
                    if (index < iterations / (maxIterations / originalText.length)) {
                        return originalText[index];
                    }
                    return chars[Math.floor(Math.random() * chars.length)];
                }).join('');
                
                iterations++;
                if (iterations >= maxIterations) {
                    clearInterval(element.scrambleInterval);
                    element.innerText = originalText;
                    if(originalText === "System.Profile") element.innerHTML = "System.Profile<span class=\"blinking-cursor\"></span>";
                }
            }, 30);
        }

        // --- LIVE WEATHER FETCH ---
        async function fetchWeather() {
